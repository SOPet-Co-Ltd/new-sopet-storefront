# Browser GraphQL endpoint (proxied via next.config rewrites)
NEXT_PUBLIC_GRAPHQL_URL=/graphql
# Server-side GraphQL endpoint (direct backend URL)
GRAPHQL_SSR_URL=http://localhost:3002/graphql
# Must match backend OMISE_PUBLIC_KEY (Omise.js tokenization in browser)
NEXT_PUBLIC_OMISE_PUBLIC_KEY=

# Meta App ID for Messenger share dialog on product pages (optional; Messenger share may fail without it)
NEXT_PUBLIC_FACEBOOK_APP_ID=

# Public site origin for canonical URLs, Open Graph, sitemap, and robots (no trailing slash required)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Brand name used in title templates and Open Graph siteName
NEXT_PUBLIC_SITE_NAME=Sopet
# Google Search Console HTML tag verification token (optional; public NEXT_PUBLIC_* only)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: override GraphQL schema path for codegen (default: ../sopet-backend/src/schema.gql)
# GRAPHQL_SCHEMA_PATH=../sopet-backend/src/schema.gql
# Vercel/CI: fetched from GitHub when local schema is missing (see scripts/ensure-graphql-schema.mjs)
# GRAPHQL_SCHEMA_GITHUB_OWNER=
# GRAPHQL_SCHEMA_GITHUB_REPO=new-sopet-backend
# GRAPHQL_SCHEMA_GITHUB_REF=main
