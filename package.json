{
  "name": "sopet-storefront",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "preinstall": "npx only-allow yarn",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "graphql:codegen": "graphql-codegen --config codegen.ts && node ./scripts/fix-graphql-codegen-duplicates.mjs src/lib/graphql/generated/graphql.ts",
    "graphql:watch": "graphql-codegen --config codegen.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prebuild": "yarn graphql:codegen"
  },
  "dependencies": {
    "@apollo/client": "^4.2.4",
    "@lottiefiles/dotlottie-react": "^0.19.7",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "graphql": "16.11.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rxjs": "^7.8.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/typed-document-node": "^7.0.3",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.5",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
